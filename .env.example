# ──────────────────────────────────────────────
# AgendaYa — Environment Variables
# Copia este archivo como .env y completa los valores
# ──────────────────────────────────────────────

# ─── Supabase ──────────────────────────────────
# URL del proyecto y anon key (públicas, del lado cliente)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# URL y service role key (SOLO del lado servidor — Netlify Functions)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Groq API (IA) ────────────────────────────
# Clave para el proxy de IA (servidor).
GROQ_API_KEY=gsk_your_groq_api_key
# Clave para llamadas directas desde el navegador en desarrollo (dev).
# Debe tener el mismo valor que GROQ_API_KEY.
VITE_GROQ_API_KEY=gsk_your_groq_api_key

# ─── PayPal ────────────────────────────────────
# Client ID (público, del lado cliente)
VITE_PAYPAL_CLIENT_ID=your-paypal-client-id
# Client ID y Secret (servidor)
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_SECRET=your-paypal-secret
# Activar sandbox (true/false)
PAYPAL_SANDBOX=true

# ─── Wompi (Pagos Colombia) ───────────────────
WOMPI_PUBLIC_KEY=pub_your_wompi_public_key
WOMPI_PRIVATE_KEY=prv_your_wompi_private_key
WOMPI_INTEGRITY_SECRET=your_wompi_integrity_secret
WOMPI_SANDBOX=true

# ─── Netlify ───────────────────────────────────
# URL del sitio (se asigna automáticamente en Netlify)
SITE_URL=https://your-site.netlify.app
